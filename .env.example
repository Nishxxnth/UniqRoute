# OpenWeatherMap — live weather data (rain, humidity, storm codes)
# Get your free key at: https://openweathermap.org/api
OWM_KEY=your_openweathermap_api_key_here

# Anthropic Claude — powers the "Explain Routes" button in the React frontend
# Get your key at: https://console.anthropic.com/
# Key format: sk-ant-api03-...
ANTHROPIC_KEY=your_anthropic_api_key_here

# Google Gemini — only needed for the legacy Streamlit app (app.py), NOT the React frontend
# Get your key at: https://aistudio.google.com/
# GEMINI_KEY=your_google_gemini_api_key_here

# TomTom Traffic — live traffic speeds for congestion-aware routing
# Get your free key at: https://developer.tomtom.com (2,500 req/day free)
# Without this key, the system falls back to a time-of-day heuristic model
TOMTOM_KEY=your_tomtom_api_key_here